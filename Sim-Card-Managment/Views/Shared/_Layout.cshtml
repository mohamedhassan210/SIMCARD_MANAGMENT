<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sim_Card_Managment</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Sim_Card_Managment.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/main.css"/>
    <link rel="stylesheet" href="~/css/all.min.css" />
    <style>
   
     
    </style>
</head>
<body>
    <div class="position-fixed top-50 start-0 bg-white z-3 d-flex justify-content-center align-items-center shadow " 
         style="height: 40px; width: 40px; cursor: pointer; border-radius: 0 8px 8px 0; z-index:1000"
         data-bs-toggle="offcanvas" data-bs-target="#leftSidebar" aria-controls="leftSidebar">

        <!-- Spinning Gear Icon -->
        <svg class="animate-spin text-dark svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.991,10H19.42a1.039,1.039,0,0,1-.951-.674l-.005-.013a1.04,1.04,0,0,1,.2-1.146l1.11-1.11a1.01,1.01,0,0,0,0-1.428l-1.4-1.4a1.01,1.01,0,0,0-1.428,0l-1.11,1.11a1.04,1.04,0,0,1-1.146.2l-.013,0A1.04,1.04,0,0,1,14,4.579V3.009A1.009,1.009,0,0,0,12.991,2H11.009A1.009,1.009,0,0,0,10,3.009v1.57a1.04,1.04,0,0,1-.674.952l-.013,0a1.04,1.04,0,0,1-1.146-.2l-1.11-1.11a1.01,1.01,0,0,0-1.428,0l-1.4,1.4a1.01,1.01,0,0,0,0,1.428l1.11,1.11a1.04,1.04,0,0,1,.2,1.146l0,.013A1.039,1.039,0,0,1,4.58,10H3.009A1.009,1.009,0,0,0,2,11.009v1.982A1.009,1.009,0,0,0,3.009,14H4.58a1.039,1.039,0,0,1,.951.674l0,.013a1.04,1.04,0,0,1-.2,1.146l-1.11,1.11a1.01,1.01,0,0,0,0,1.428l1.4,1.4a1.01,1.01,0,0,0,1.428,0l1.11-1.11a1.04,1.04,0,0,1,1.146-.2l.013.005A1.039,1.039,0,0,1,10,19.42v1.571A1.009,1.009,0,0,0,11.009,22h1.982A1.009,1.009,0,0,0,14,20.991V19.42a1.039,1.039,0,0,1,.674-.951l.013-.005a1.04,1.04,0,0,1,1.146.2l1.11,1.11a1.01,1.01,0,0,0,1.428,0l1.4-1.4a1.01,1.01,0,0,0,0-1.428l-1.11-1.11a1.04,1.04,0,0,1-.2-1.146l.005-.013A1.039,1.039,0,0,1,19.42,14h1.571A1.009,1.009,0,0,0,22,12.991V11.009A1.009,1.009,0,0,0,20.991,10ZM12,15a3,3,0,1,1,3-3A3,3,0,0,1,12,15Z" />
        </svg>
    </div>
    <!-- Offcanvas Sidebar Component -->
    <!-- Added data-bs-theme="dark" so the close button and accordion arrows automatically turn white -->
    <aside class="offcanvas offcanvas-start bg-black bg-opacity-25  border-end border-secondary" tabindex="-1" id="leftSidebar" aria-labelledby="leftSidebarLabel" data-bs-theme="dark" style="border-radius: 0px 30px 30px 0px">

        <!-- Sidebar Header -->
        <div class="offcanvas-header ">

            <button type="button" class="btn-close bg-white " data-bs-dismiss="offcanvas" aria-label="Close"   >

                <i class="fa-solid fa-x " style="font-size: 21px"></i>

            </button>
        </div>

        <!-- Sidebar Menu Container -->
        <div class="accordion sidebar-accordion mx-auto g-5
 " id="sidebarMenu" style="max-width: 400px ;">

            <!-- ==================== USER SECTION ==================== -->
            <div class="accordion-item mb-2">
                <!-- Header Toggle -->
                <div class="d-flex align-items-center gap-3 sidebar-toggle-btn" data-bs-toggle="collapse" data-bs-target="#collapseUser" aria-expanded="true" style="cursor: pointer;">
                    <!-- Triangle Box -->
                    <div class="triangle-box rounded-3 d-flex justify-content-center align-items-center text-secondary">
                        <svg class="toggle-triangle" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 6l-6 10h12z" />
                        </svg>
                    </div>
                    <!-- Orange Icon Box -->
                    <div class="icon-box-main rounded-3 d-flex justify-content-center align-items-center text-white">
                        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                        </svg>
                    </div>
                    <span class="text-white fs-6">User</span>
                </div>

                <!-- Body / Sub-items -->
                <div id="collapseUser" class="accordion-collapse collapse show" data-bs-parent="#sidebarMenu">
                    <div class="accordion-body p-0 pt-3 pb-3 ms-2">
                        <!-- Sub 1 -->
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <i class="fa-solid fa-plus "></i>
                            </div>
                            <span class="sub-item-text">Create new user</span>
                        </div>
                        <!-- Sub 2 -->
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="3" y="6" width="18" height="12" rx="2" ry="2"></rect>
                                    <circle cx="8.5" cy="12" r="2.5"></circle>
                                    <path d="M14 10h4m-4 4h4"></path>
                                </svg>
                            </div>
                            <span class="sub-item-text">Manage Permissions</span>
                        </div>
                        <!-- Sub 3 -->
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <i class="fa-solid fa-plus"></i>
                            </div>
                            <span class="sub-item-text">Create new user</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ==================== SIM CARDS SECTION ==================== -->
            <div class="accordion-item mb-2">
                <!-- Header Toggle -->
                <div class="d-flex align-items-center gap-3 sidebar-toggle-btn" data-bs-toggle="collapse"
                     data-bs-target="#collapseSim" aria-expanded="true" style="cursor: pointer;">
                    <!-- Triangle Box -->
                    <div class="triangle-box rounded-3 d-flex justify-content-center align-items-center text-secondary">
                        <svg class="toggle-triangle" width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <path d="M12 6l-6 10h12z" />
                        </svg>
                    </div>
                    <!-- Orange Icon Box -->
                    <div class="icon-box-main rounded-3 d-flex justify-content-center align-items-center text-white">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18 2h-8L4 8v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM7 17h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2zM7 13h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2z" />
                        </svg>
                    </div>
                    <span class="text-white fs-6">SIM cards</span>
                </div>

                <!-- Body / Sub-items -->
                <div id="collapseSim" class="accordion-collapse collapse show" data-bs-parent="#sidebarMenu">
                    <div class="accordion-body p-0 pt-3 pb-3 ms-2">
                        <!-- Sub 1 -->
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.5">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                    <line x1="12" y1="18" x2="12" y2="12"></line>
                                    <line x1="9" y1="15" x2="15" y2="15"></line>
                                </svg>
                            </div>
                            <span class="sub-item-text">Create new SIM</span>
                        </div>
                        <!-- Sub 2 -->
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.5">
                                    <rect x="3" y="6" width="18" height="12" rx="2" ry="2"></rect>
                                    <circle cx="8.5" cy="12" r="2.5"></circle>
                                    <path d="M14 10h4m-4 4h4"></path>
                                </svg>
                            </div>
                            <span class="sub-item-text">Manage Permissions</span>
                        </div>
                        <!-- Sub 3 -->
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <i class="fa-solid fa-plus"></i>

                            </div>
                            <span class="sub-item-text">Create new user</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ==================== USB SECTION ==================== -->
            <div class="accordion-item">
                <!-- Header Toggle -->
                <div class="d-flex align-items-center gap-3 sidebar-toggle-btn" data-bs-toggle="collapse"
                     data-bs-target="#collapseUsb" aria-expanded="true" style="cursor: pointer;">
                    <!-- Triangle Box -->
                    <div class="triangle-box rounded-3 d-flex justify-content-center align-items-center text-secondary">
                        <svg class="toggle-triangle" width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <path d="M12 6l-6 10h12z" />
                        </svg>
                    </div>
                    <!-- Orange Icon Box (Using exact SIM icon per design image) -->
                    <div class="icon-box-main rounded-3 d-flex justify-content-center align-items-center text-white">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18 2h-8L4 8v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM7 17h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2zM7 13h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2z" />
                        </svg>
                    </div>
                    <span class="text-white fs-6">USB</span>
                </div>

                <!-- Body / Sub-items -->
                <div id="collapseUsb" class="accordion-collapse collapse show" data-bs-parent="#sidebarMenu">
                    <div class="accordion-body p-0 pt-3 pb-3 ms-2">
                        <!-- Sub 1 -->
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.5">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                </svg>
                            </div>
                            <span class="sub-item-text">Create new USB</span>
                        </div>
                        <!-- Sub 2 -->
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.5">
                                    <rect x="3" y="6" width="18" height="12" rx="2" ry="2"></rect>
                                    <circle cx="8.5" cy="12" r="2.5"></circle>
                                    <path d="M14 10h4m-4 4h4"></path>
                                </svg>
                            </div>
                            <span class="sub-item-text">Manage Permissions</span>
                        </div>
                        <!-- Sub 3 -->
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box-sub rounded-3 d-flex justify-content-center align-items-center text-white">
                                <i class="fa-solid fa-plus"></i>

                            </div>
                            <span class="sub-item-text">Create new user</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </aside>
    <nav class=" position-absolute top-0 navbar navbar-expand-lg w-100">
        <div class="container">
            <a class="navbar-brand text-white fw-bold" asp-controller="Home" asp-action="Index">FATHALL SIM</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                <ul class="navbar-nav border border-1 border-white rounded-pill p-2 text-white bg-blur">
                    <li class="nav-item ">
                        <a class="nav-link fw-bold px-4 text-black active" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-bold px-4 text-black" asp-controller="Home" asp-action="Sim">Sim</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-bold px-4 text-black" asp-controller="Home" asp-action="Usb">Usb</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-bold px-4 text-black" asp-controller="Employee" asp-action="Index">Employees</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/highcharts.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
