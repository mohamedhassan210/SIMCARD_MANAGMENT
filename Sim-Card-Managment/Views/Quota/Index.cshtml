@model IEnumerable<Sim_Card_Managment.Models.Quota>

@{
    ViewData["Title"] = "Quota List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quota Plans</h2>
        <a asp-action="Create" class="btn btn-primary">Create New Quota</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Base Amount (GB)</th>
                    <th>Extra Amount (GB)</th>
                    <th>Period</th>
                    <th>Valid From</th>
                    <th>Valid To</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.BaseAmount</td>
                        <td>@item.ExtraAmount</td>
                        <td>@item.Period</td>
                        <td>@item.ValidFrom?.ToString("yyyy-MM-dd")</td>
                        <td>@item.ValidTo?.ToString("yyyy-MM-dd")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>