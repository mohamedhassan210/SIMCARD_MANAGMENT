@model Sim_Card_Managment.Models.Quota

@{
    ViewData["Title"] = "Delete Quota";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm col-md-8 mx-auto">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Are you sure you want to delete this?</h3>
        </div>
        <div class="card-body">
            <p class="text-danger fw-bold">Warning: This action cannot be undone!</p>
            <dl class="row">
                <dt class="col-sm-4">Base Amount</dt>
                <dd class="col-sm-8">@Model.BaseAmount GB</dd>

                <dt class="col-sm-4">Period</dt>
                <dd class="col-sm-8">@Model.Period</dd>

                <dt class="col-sm-4">Valid Dates</dt>
                <dd class="col-sm-8">@Model.ValidFrom?.ToString("yyyy-MM-dd") to @Model.ValidTo?.ToString("yyyy-MM-dd")</dd>
            </dl>
        </div>
        <div class="card-footer bg-light">
            <form asp-action="DeleteConfirmed" method="post" asp-route-id="@Model.Id">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger w-100">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-secondary w-100">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@{
    @Html.AntiForgeryToken();
}