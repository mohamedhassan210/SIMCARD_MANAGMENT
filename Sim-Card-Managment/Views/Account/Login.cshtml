
<style>
    /* =========================================
       Login Page Styles
       ========================================= */

    /* Main background section */
    .login-section {
        background-color: #E24D17;
    }

    /* Centered white login card */
    .login-card {
        border-radius: 24px;
        width: 100%;
        max-width: 600px;
        min-height: 500px;
        justify-content: center; /* Aligns inner flex items */
    }

    /* Heading styling */
    .login-title {
        font-size: 32px;
    }

    /* Input fields (Overrides default bootstrap focus shadows) */
    .login-input {
        font-size: 0.9rem;
        box-shadow: none;
    }

    /* Custom button styling */
    .login-btn {
        background-color: #E24D17;
        font-size: 1rem;
        border: 2px solid #E24D17;
    }

        /* Optional: Added a hover effect for better UX */
        .login-btn:hover {
            background-color: #c74213;
            border-color: #c74213;
            color: #ffffff;
        }

    /* Bottom text links */
    .forgot-password-link {
        font-size: 0.8rem;
        color: #333333;
    }

    /* Highlighted 'reset it' text */
    .reset-text {
        color: #E24D17;
    }

    .form-control
    {
        border:2px solid transparent !important;
    }
    .form-control:focus
    {
        box-shadow:none !important;
        border: 2px solid #E24D17 !important;
    }
</style>


<section class="login-section position-relative vh-100 vw-100 overflow-hidden">
    <div class="d-flex h-100 w-100 align-items-center justify-content-center position-relative">

        <div class="login-card bg-white d-flex flex-column align-items-center px-4 py-5 shadow-lg">

            <h2 class="login-title text-center fw-bolder text-dark mb-5">Login</h2>

            <div class="d-flex flex-column align-items-center w-100 px-2">

                <input type="text"
                       placeholder="user name"
                       class="login-input form-control bg-light border-0 rounded-pill mb-3 px-4 py-3 text-dark w-100  ">

                <input type="password"
                       placeholder="Password"
                       class="login-input form-control bg-light border-0 rounded-pill mb-4 px-4 py-3 text-dark w-100">

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

                <form asp-controller="Account" asp-action="Login" method="post" class="d-flex flex-column align-items-center w-100">

                    @Html.AntiForgeryToken()

                    <div class="w-100 mb-4" style="margin-top: 50px;">
                        <input asp-for="Username" type="text" placeholder="Username" class="custom-input w-100 ps-3 text-dark">
                        <span asp-validation-for="Username" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="w-100 mb-4">
                        <input asp-for="Password" type="password" placeholder="Password" class="custom-input w-100 ps-3 text-dark">
                        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-check mb-4 align-self-start ms-2">
                        <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                        <label asp-for="RememberMe" class="form-check-label text-white small">Remember Me</label>
                    </div>

                    <a asp-action="ResetPassword" class="text-white text-decoration-none mb-4 small">
                        Forgot your password? <span style="color: #E24D17;">reset it</span>
                    </a>

                    <button type="submit" class="btn custom-btn">Login</button>
                </form>
            </div>

        </div>

        <div class="bg-shape shape-solid z-1"></div>
        <div class="bg-shape shape-outline z-1"></div>
    </section>

    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>

</html>