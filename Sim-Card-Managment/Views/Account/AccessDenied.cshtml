@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center mt-5">
    <div class="alert alert-danger p-5 shadow-sm">
        <h1 class="display-4 text-danger">403 - Access Denied</h1>
        <p class="lead mt-3">Sorry, you do not have the required permissions to access this page.</p>
        <hr class="my-4">
        <p class="text-muted">Please contact your administrator if you believe this is a mistake.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-danger mt-2">Back to Home</a>
    </div>
</div>