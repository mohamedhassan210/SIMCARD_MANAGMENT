@model Sim_Card_Managment.Viewmodel.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0"><i class="ti ti-lock-question me-2"></i>Reset Access</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Enter the email address associated with your account. If an account is found with an active verification token, we will email you your dynamic login code.
                    </p>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label font-weight-medium">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg"
                                   placeholder="name@company.com" autocomplete="email" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-dark btn-lg">
                                Send Recovery Email
                            </button>
                            <a asp-action="Login" class="btn btn-link text-secondary btn-sm mt-2">
                                Back to Sign In
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}