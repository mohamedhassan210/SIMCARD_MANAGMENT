@model Sim_Card_Managment.Viewmodel.VerifyOtpViewModel

@{
    ViewData["Title"] = "Verify Access Code";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Enter Security Code</h4>
                </div>
                <div class="card-body p-4">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <p class="text-muted mb-4">
                        We have sent a security token to <strong>@Model.Email</strong>.
                    </p>

                    <form asp-action="VerifyOtp" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Email" />

                        <div class="mb-4">
                            <label asp-for="OtpCode" class="form-label">One-Time Password (OTP)</label>
                            <input asp-for="OtpCode" class="form-control text-center font-monospace" placeholder="000000" autocomplete="off" />
                            <span asp-validation-for="OtpCode" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-dark btn-lg">Confirm & Login</button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <form asp-action="ResendOtp" method="post" class="text-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="email" value="@Model.Email" />
                        <p class="text-muted small mb-1">Didn't receive the email code?</p>
                        <button type="submit" class="btn btn-link text-primary p-0 m-0 align-baseline">Resend OTP Code</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>