<style>
    /* =========================================
           Employee Dashboard Styles
           ========================================= */

    /* Brand Colors */
    :root {
        --brand-orange: #E24D17;
        --bg-light: #F0F0F0;
        --border-gray: #D1D1D1;
    }

    /* Background Color for the whole page */
    .main-bg {
        background-color: var(--bg-light);
    }

    /* Typography & Utility Colors */
    .text-brand-orange {
        color: var(--brand-orange) !important;
    }

    .bg-brand-orange {
        background-color: var(--brand-orange) !important;
    }

    /* Buttons */
    .btn-brand-orange {
        background-color: var(--brand-orange) !important;
        border-color: var(--brand-orange) !important;
        transition: all 0.2s ease-in-out;
    }

        .btn-brand-orange:hover {
            background-color: #c74213 !important;
            border-color: #c74213 !important;
            color: white !important;
        }

    /* Search Bar Wrapper */
    .custom-search-wrapper {
        background-color: transparent;
        border: 1px solid var(--border-gray);
        max-width: 400px;
        width: 100%;
    }

        .custom-search-wrapper:focus-within {
            border-color: var(--brand-orange);
            background-color: white;
        }

    /* Table Container (Orange Outline Box) */
    .table-container {
        border: 1px solid var(--brand-orange);
        height: 500px; /* Adjust height as needed to force scrollbar */
    }

    /* Table Resets (Removing unwanted borders) */
    .custom-table th,
    .custom-table td {
        border-bottom: none !important;
        border-right: none !important;
        border-left: none !important;
        vertical-align: middle;
    }

    .custom-table tbody tr {
        border-bottom: none !important;
    }

    /* Badges styling */
    .badge {
        font-size: 0.65rem;
        letter-spacing: 0.5px;
    }

    /* =========================================
           Custom Scrollbar
           ========================================= */
    .custom-scrollbar {
        max-height: 150px; /* Adjust inner container height for scrolling */
        overflow-y: auto;
    }

        /* Scrollbar Track */
        .custom-scrollbar::-webkit-scrollbar {
            width: 25px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: #E5E5E5;
            border-radius: 10px;
        }

        /* Scrollbar Thumb (The orange pill) */
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background-color: var(--brand-orange);
            border-radius: 10px;
            border: 3px solid #E5E5E5; /* Creates padding effect inside the track */
        }

            .custom-scrollbar::-webkit-scrollbar-thumb:hover {
                background-color: #c74213;
            }
</style>

